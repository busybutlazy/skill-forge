#!/usr/bin/env sh

set -eu

SCRIPT_PATH=$0
while [ -L "$SCRIPT_PATH" ]; do
    LINK_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
    SCRIPT_PATH=$(readlink "$SCRIPT_PATH")
    case "$SCRIPT_PATH" in
        /*) ;;
        *) SCRIPT_PATH="$LINK_DIR/$SCRIPT_PATH" ;;
    esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
PROJECT_DIR=$(pwd)
OUTPUT_DIR="${SKILL_TOOLKIT_OUTPUT_HOST_DIR:-$PROJECT_DIR/.skill-toolkit-output}"
HOST_UID=$(id -u)
HOST_GID=$(id -g)

mkdir -p "$OUTPUT_DIR"

exec env \
    HOST_UID="$HOST_UID" \
    HOST_GID="$HOST_GID" \
    SKILL_TOOLKIT_PROJECT_HOST_DIR="$PROJECT_DIR" \
    SKILL_TOOLKIT_OUTPUT_HOST_DIR="$OUTPUT_DIR" \
    docker compose \
    -f "$SCRIPT_DIR/compose.yaml" \
    run --rm toolkit "$@"
