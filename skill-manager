#!/usr/bin/env sh

set -eu

print_help() {
    cat <<'EOF'
Usage:
  skill-manager
  skill-manager shell
  skill-manager help
  skill-manager <skill-toolkit arguments>

Behavior:
  - No arguments: open the interactive menu for the current project directory
  - shell: open the runtime container's expert terminal
  - help, -h, --help: show this help text locally without starting Docker
  - any other arguments: pass them through to the containerized skill-toolkit CLI

Examples:
  skill-manager
  skill-manager shell
  skill-manager validate
  skill-manager list --target codex --project /workspace/project --json
EOF
}

case "${1:-}" in
    help|-h|--help)
        print_help
        exit 0
        ;;
esac

SCRIPT_PATH=$0
while [ -L "$SCRIPT_PATH" ]; do
    LINK_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
    SCRIPT_PATH=$(readlink "$SCRIPT_PATH")
    case "$SCRIPT_PATH" in
        /*) ;;
        *) SCRIPT_PATH="$LINK_DIR/$SCRIPT_PATH" ;;
    esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd)
PROJECT_DIR=$(pwd)
OUTPUT_DIR="${SKILL_TOOLKIT_OUTPUT_HOST_DIR:-$PROJECT_DIR/.skill-toolkit-output}"
HOST_UID=$(id -u)
HOST_GID=$(id -g)

mkdir -p "$OUTPUT_DIR"

exec env \
    HOST_UID="$HOST_UID" \
    HOST_GID="$HOST_GID" \
    SKILL_TOOLKIT_PROJECT_HOST_DIR="$PROJECT_DIR" \
    SKILL_TOOLKIT_OUTPUT_HOST_DIR="$OUTPUT_DIR" \
    docker compose \
    -f "$SCRIPT_DIR/compose.yaml" \
    run --rm toolkit "$@"
