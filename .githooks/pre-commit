#!/usr/bin/env bash
set -euo pipefail

# Only run if canonical-skills files are staged
if ! git diff --cached --name-only | grep -q "^canonical-skills/"; then
    exit 0
fi

echo "[pre-commit] canonical-skills changed — validating skill hashes..."

if ! command -v docker &>/dev/null; then
    echo "[pre-commit] ERROR: docker not found; cannot validate skill hashes" >&2
    exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Build dev image if not already available
if ! docker image inspect skill-forge-dev &>/dev/null; then
    echo "[pre-commit] Building skill-forge-dev image..."
    docker build -q -f "$REPO_ROOT/Dockerfile.dev" -t skill-forge-dev "$REPO_ROOT"
fi

docker run --rm \
    -v "$REPO_ROOT":/workspace \
    -w /workspace \
    skill-forge-dev \
    bash -c "pip install -e . pytest -q 2>/dev/null && python -m pytest tests/test_skill_forge.py::ValidationTests::test_all_canonical_skills_validate -q"
